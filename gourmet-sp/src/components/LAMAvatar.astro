---
// LAMAvatar.astro - LAM 3D Avatar Component using gaussian-splat-renderer-for-lam
// This component renders a 3D avatar using WebGL Gaussian Splatting
// With OpenAvatarChat WebSocket integration for real-time lip sync

export interface Props {
  avatarPath?: string;  // Path to avatar .zip file
  width?: string;
  height?: string;
  wsUrl?: string;       // WebSocket URL for OpenAvatarChat backend
  autoConnect?: boolean; // Auto-connect to WebSocket on load
}

const {
  avatarPath = '/avatar/concierge.zip',
  width = '100%',
  height = '100%',
  wsUrl = '',
  autoConnect = false
} = Astro.props;
---

<div
  class="lam-avatar-container"
  id="lamAvatarContainer"
  data-avatar-path={avatarPath}
  data-ws-url={wsUrl}
  data-auto-connect={autoConnect.toString()}
  style={`width: ${width}; height: ${height};`}
>
  <div class="lam-avatar-canvas" id="lamAvatarCanvas"></div>
  <div class="lam-avatar-loading" id="lamAvatarLoading">
    <div class="spinner"></div>
    <p>Loading 3D Avatar...</p>
  </div>
  <div class="lam-avatar-fallback" id="lamAvatarFallback">
    <img src="/images/avatar-anime.png" alt="AI Avatar" class="fallback-img" />
  </div>
</div>

<style>
.lam-avatar-container {
  position: relative;
  background: transparent;
  overflow: hidden;
}

.lam-avatar-canvas {
  width: 100%;
  height: 100%;
  display: none;
}

.lam-avatar-canvas.ready {
  display: block;
}

.lam-avatar-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  z-index: 10;
}

.lam-avatar-loading.hidden {
  display: none;
}

.lam-avatar-loading .spinner {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(6, 182, 212, 0.3);
  border-top-color: #06b6d4;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 12px;
}

.lam-avatar-loading p {
  color: #0891b2;
  font-size: 14px;
  font-weight: 500;
}

.lam-avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lam-avatar-fallback.hidden {
  display: none;
}

.fallback-img {
  max-width: 80%;
  max-height: 80%;
  object-fit: contain;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
</style>

<script>
/**
 * LAM Avatar Controller with OpenAvatarChat WebSocket Integration
 *
 * Usage in your local environment:
 * 1. Install NPM package: npm install gaussian-splat-renderer-for-lam
 * 2. Place avatar .zip file in public/avatar/ directory
 * 3. Connect to OpenAvatarChat backend for real-time lip sync
 */

import {
  LAMWebSocketManager,
  type ExpressionData,
  type ExpressionFrameData,
  type MotionData,
  ARKIT_CHANNEL_NAMES
} from '../scripts/lam/lam-websocket-manager';

type ChatState = 'Idle' | 'Listening' | 'Thinking' | 'Responding';

// 全52チャンネルを0で初期化
function createDefaultExpressionData(): ExpressionData {
  const data: ExpressionData = {};
  ARKIT_CHANNEL_NAMES.forEach(name => {
    data[name] = 0;
  });
  return data;
}

/**
 * LAM Avatar Controller with Official OpenAvatarChat Sync Approach
 *
 * Synchronization mechanism:
 * - Server bundles audio + expression data in JBIN format
 * - AudioSyncPlayer plays audio and tracks playback position
 * - Expression frames are synced based on audio playback time
 * - No need for separate TTS event hooks
 */
class LAMAvatarController {
  private container: HTMLElement;
  private canvas: HTMLElement;
  private loading: HTMLElement;
  private fallback: HTMLElement;
  private avatarPath: string;
  private wsUrl: string;
  private autoConnect: boolean;
  private renderer: any = null;
  private wsManager: LAMWebSocketManager | null = null;
  private currentState: ChatState = 'Idle';
  private expressionData: ExpressionData = createDefaultExpressionData();
  private isInitialized = false;

  // Sync modes:
  // - 'bundled': Official approach - audio + expression bundled from WebSocket
  // - 'external': Hybrid approach - external TTS player + expression from WebSocket
  private expressionUpdateInterval: number | null = null;
  private syncMode: 'bundled' | 'external' = 'external';  // Default to external for gourmet-sp compatibility

  // External TTS sync: Reference to external audio player and timing
  private externalTtsPlayer: HTMLAudioElement | null = null;
  private externalTtsStartTime: number = 0;
  private externalTtsDuration: number = 0;

  // Frame buffer for expression (used in external sync mode)
  private frameBuffer: ExpressionData[] = [];
  private frameQueue: ExpressionData[][] = [];
  private frameIndex: number = 0;
  private frameRate: number = 30;
  private framePlaybackTimer: number | null = null;
  private isPlayingFrames: boolean = false;
  private waitingForAudio: boolean = false;

  constructor(container: HTMLElement) {
    this.container = container;
    this.canvas = container.querySelector('#lamAvatarCanvas') as HTMLElement;
    this.loading = container.querySelector('#lamAvatarLoading') as HTMLElement;
    this.fallback = container.querySelector('#lamAvatarFallback') as HTMLElement;
    this.avatarPath = container.dataset.avatarPath || '/avatar/concierge.zip';
    this.wsUrl = container.dataset.wsUrl || '';
    this.autoConnect = container.dataset.autoConnect === 'true';

    this.init();
  }

  private async init() {
    try {
      // Try to load the LAM WebGL renderer
      await this.loadRenderer();

      // Start expression sync timer (for bundled audio+expression sync)
      this.startExpressionSyncTimer();

      // デバッグ：レンダラー状態を定期的にチェック
      setInterval(() => {
        const canvasVisible = this.canvas.classList.contains('ready');
        const jawOpen = this.expressionData['jawOpen'] || 0;
        const mouthLowerDownLeft = this.expressionData['mouthLowerDownLeft'] || 0;
        const mouthLowerDownRight = this.expressionData['mouthLowerDownRight'] || 0;
        const isAudioPlaying = this.wsManager?.isAudioPlaying() || false;
        console.log(`[LAM Health] canvas=${canvasVisible}, renderer=${!!this.renderer}, state=${this.currentState}, audioPlaying=${isAudioPlaying}, jaw=${jawOpen.toFixed(3)}, mouthLD_L=${mouthLowerDownLeft.toFixed(3)}, mouthLD_R=${mouthLowerDownRight.toFixed(3)}`);
      }, 2000);

      // Auto-connect to WebSocket if configured
      if (this.autoConnect && this.wsUrl) {
        await this.connectWebSocket(this.wsUrl);
      }
    } catch (error) {
      console.warn('LAM WebGL renderer not available, using fallback image:', error);
      this.showFallback();
    }
  }

  /**
   * Start the expression sync timer
   * Supports two modes:
   * - 'bundled': Get expression based on AudioSyncPlayer position (official approach)
   * - 'external': Get expression based on external TTS player position (gourmet-sp compatible)
   */
  private startExpressionSyncTimer(): void {
    if (this.expressionUpdateInterval) {
      clearInterval(this.expressionUpdateInterval);
    }

    // Update expression at 30fps
    this.expressionUpdateInterval = window.setInterval(() => {
      if (this.syncMode === 'bundled') {
        // Bundled mode: Get expression from WebSocket manager based on its AudioSyncPlayer
        if (!this.wsManager) return;

        const frame = this.wsManager.getCurrentExpressionFrame();
        if (frame) {
          Object.keys(frame).forEach(key => {
            this.expressionData[key] = frame[key];
          });
          if (this.currentState !== 'Responding') {
            this.setChatState('Responding');
          }
        } else if (this.currentState === 'Responding' && !this.wsManager.isAudioPlaying()) {
          this.resetExpression();
          this.setChatState('Idle');
        }
      } else {
        // External mode: Get expression based on external TTS player position
        this.syncExpressionWithExternalPlayer();
      }
    }, 1000 / 30);  // 30fps
  }

  /**
   * Sync expression with external TTS player position
   * Used in 'external' sync mode for gourmet-sp compatibility
   */
  private syncExpressionWithExternalPlayer(): void {
    // Check if we have frames and an external player
    if (this.frameBuffer.length === 0 || !this.isPlayingFrames) {
      return;
    }

    // Calculate frame index based on external player position or elapsed time
    let currentTimeMs: number;
    if (this.externalTtsPlayer && !this.externalTtsPlayer.paused) {
      currentTimeMs = this.externalTtsPlayer.currentTime * 1000;
    } else if (this.externalTtsStartTime > 0) {
      currentTimeMs = Date.now() - this.externalTtsStartTime;
    } else {
      return;
    }

    // Calculate frame index
    const frameIndex = Math.floor((currentTimeMs / 1000) * this.frameRate);

    if (frameIndex >= this.frameBuffer.length) {
      // Playback complete
      return;
    }

    // Apply frame
    const frame = this.frameBuffer[frameIndex];
    if (frame) {
      Object.keys(frame).forEach(key => {
        this.expressionData[key] = frame[key];
      });
    }
  }

  /**
   * Set the external TTS player for sync
   * Call this to link the LAMAvatar with an external audio element
   */
  public setExternalTtsPlayer(player: HTMLAudioElement): void {
    this.externalTtsPlayer = player;
    this.syncMode = 'external';

    // Listen for play/pause/ended events
    player.addEventListener('play', () => {
      console.log('[LAM External] TTS play event');
      this.externalTtsStartTime = Date.now() - (player.currentTime * 1000);
      this.startFramePlaybackFromQueue();
    });

    player.addEventListener('pause', () => {
      console.log('[LAM External] TTS pause event');
      // Don't stop playback on pause - may resume
    });

    player.addEventListener('ended', () => {
      console.log('[LAM External] TTS ended event');
      this.stopFramePlayback();
    });

    console.log('[LAM Avatar] External TTS player linked');
  }

  /**
   * Switch sync mode
   */
  public setSyncMode(mode: 'bundled' | 'external'): void {
    this.syncMode = mode;
    console.log(`[LAM Avatar] Sync mode set to: ${mode}`);
  }

  private async loadRenderer() {
    // Dynamic import of the gaussian-splat-renderer-for-lam package
    // This will fail gracefully if the package is not installed
    try {
      const GaussianSplats3D = await import('gaussian-splat-renderer-for-lam');

      this.renderer = await GaussianSplats3D.GaussianSplatRenderer.getInstance(
        this.canvas,
        this.avatarPath,
        {
          getChatState: () => this.getChatState(),
          getExpressionData: () => this.getExpressionData(),
          backgroundColor: '0xbae6fd', // Light blue background
          alpha: 0.0 // Transparent background
        }
      );

      this.isInitialized = true;
      this.showCanvas();
      console.log('LAM Avatar initialized successfully');

      // デバッグ：レンダラーのmorphTargetDictionaryを確認
      setTimeout(() => {
        try {
          const splatMesh = (this.renderer as any)?.viewer?.splatMesh;
          if (splatMesh?.morphTargetDictionary) {
            const dict = splatMesh.morphTargetDictionary;
            const mouthKeys = Object.keys(dict).filter(k => k.toLowerCase().includes('mouth') || k.toLowerCase().includes('jaw'));
            console.log('[LAM Debug] morphTargetDictionary mouth/jaw keys:', mouthKeys);
            console.log('[LAM Debug] mouthLowerDownLeft index:', dict['mouthLowerDownLeft']);
            console.log('[LAM Debug] mouthLowerDownRight index:', dict['mouthLowerDownRight']);
            console.log('[LAM Debug] jawOpen index:', dict['jawOpen']);
          } else {
            console.log('[LAM Debug] No morphTargetDictionary found on splatMesh');
          }
        } catch (e) {
          console.error('[LAM Debug] Error checking morphTargetDictionary:', e);
        }
      }, 2000);
    } catch (error) {
      throw new Error(`Failed to load LAM renderer: ${error}`);
    }
  }

  private showCanvas() {
    this.loading.classList.add('hidden');
    this.fallback.classList.add('hidden');
    this.canvas.classList.add('ready');
  }

  private showFallback() {
    this.loading.classList.add('hidden');
    this.canvas.classList.remove('ready');
    this.fallback.classList.remove('hidden');
  }

  private expressionTimeoutId: number | null = null;

  // WebSocket connection management

  public async connectWebSocket(url: string): Promise<void> {
    if (this.wsManager) {
      this.wsManager.destroy();
    }

    this.wsManager = new LAMWebSocketManager({
      // Legacy callbacks for backward compatibility (fallback mode)
      onExpressionUpdate: (data: ExpressionData) => {
        if (this.useBundledSync) return;  // Ignore in bundled mode
        try {
          const jawOpen = data['jawOpen'] || 0;
          const mouthLowerDownLeft = data['mouthLowerDownLeft'] || 0;
          console.log(`[LAM Expression] Single frame (legacy): jawOpen=${jawOpen.toFixed(3)}, mouthLD_L=${mouthLowerDownLeft.toFixed(3)}`);
          Object.keys(data).forEach(key => {
            this.expressionData[key] = data[key];
          });
        } catch (e) {
          console.error('[LAM Expression] Update error:', e);
        }
      },
      onExpressionFrames: (data: ExpressionFrameData) => {
        if (this.useBundledSync) return;  // Ignore in bundled mode
        try {
          this.frameQueue.push(data.frames);
          this.frameRate = data.frameRate;
          this.waitingForAudio = true;
          console.log(`[LAM Expression] Queued ${data.frameCount} frames (legacy mode)`);
        } catch (e) {
          console.error('[LAM Expression] Frame buffer error:', e);
        }
      },
      onAudioData: (audio: Int16Array) => {
        // Audio is now handled by AudioSyncPlayer in bundled mode
        console.log(`[LAM Audio] Received ${audio.length} samples`);
      },
      onConnectionChange: (connected: boolean) => {
        this.container.dispatchEvent(new CustomEvent('lamConnectionChange', {
          detail: { connected }
        }));
        if (connected) {
          this.setChatState('Idle');
        }
      },
      // Official sync callbacks
      onBatchStarted: (batchId: number) => {
        console.log(`[LAM Avatar] Batch ${batchId} started - audio playing`);
        this.setChatState('Responding');
        this.container.dispatchEvent(new CustomEvent('lamSpeechStart', {
          detail: { batchId }
        }));
      },
      onBatchEnded: (batchId: number) => {
        console.log(`[LAM Avatar] Batch ${batchId} ended - audio finished`);
        this.resetExpression();
        this.setChatState('Idle');
        this.container.dispatchEvent(new CustomEvent('lamSpeechEnd', {
          detail: { batchId }
        }));
      }
    });

    // Initialize the audio player (requires user interaction first)
    await this.wsManager.initializeAudio();
    await this.wsManager.connect(url);
    console.log('[LAM Avatar] WebSocket connected with bundled sync:', url);
  }

  public disconnectWebSocket(): void {
    if (this.wsManager) {
      this.wsManager.destroy();
      this.wsManager = null;
    }
  }

  public isWebSocketConnected(): boolean {
    return this.wsManager?.isConnected() ?? false;
  }

  // Audio control (delegated to WebSocket manager's AudioSyncPlayer)

  public stopAudio(): void {
    this.wsManager?.stopAudio();
  }

  public setAudioMute(muted: boolean): void {
    this.wsManager?.setAudioMute(muted);
  }

  public isAudioPlaying(): boolean {
    return this.wsManager?.isAudioPlaying() ?? false;
  }

  // ========================================
  // Frame playback for lip sync
  // ========================================

  // ★ TTS再生開始時に外部から呼び出される
  public startFramePlaybackFromQueue(): void {
    if (this.isPlayingFrames) {
      console.log('[LAM Playback] Already playing, skipping');
      return;
    }

    if (this.frameQueue.length === 0) {
      // フレームがまだ届いていない場合は、少し待ってリトライ
      console.log('[LAM Playback] No frames in queue, waiting for frames...');
      this.waitForFramesAndPlay(3, 200); // 3回リトライ、200ms間隔
      return;
    }

    // キューからフレームを取り出して結合
    this.frameBuffer = this.frameQueue.flat();
    this.frameQueue = [];  // キューをクリア
    this.waitingForAudio = false;

    this.startFramePlayback();
  }

  // フレームが届くまで待ってから再生
  private waitForFramesAndPlay(retriesLeft: number, delayMs: number): void {
    if (retriesLeft <= 0) {
      console.log('[LAM Playback] Gave up waiting for frames');
      return;
    }

    setTimeout(() => {
      if (this.isPlayingFrames) {
        return; // 既に再生中
      }

      if (this.frameQueue.length > 0) {
        console.log(`[LAM Playback] Frames arrived, starting playback (waited ${(4 - retriesLeft) * delayMs}ms)`);
        this.frameBuffer = this.frameQueue.flat();
        this.frameQueue = [];
        this.waitingForAudio = false;
        this.startFramePlayback();
      } else {
        console.log(`[LAM Playback] Still waiting for frames... (${retriesLeft - 1} retries left)`);
        this.waitForFramesAndPlay(retriesLeft - 1, delayMs);
      }
    }, delayMs);
  }

  private startFramePlayback(): void {
    if (this.isPlayingFrames || this.frameBuffer.length === 0) {
      return;
    }

    this.isPlayingFrames = true;
    this.frameIndex = 0;
    const frameInterval = 1000 / this.frameRate; // ms per frame

    console.log(`[LAM Playback] Starting frame playback: ${this.frameBuffer.length} frames at ${this.frameRate}fps (${frameInterval.toFixed(1)}ms/frame)`);

    // 状態をRespondingに設定
    if (this.currentState !== 'Responding') {
      this.setChatState('Responding');
    }

    // Apply first frame immediately
    this.applyFrame(0);

    // Start playback timer
    this.framePlaybackTimer = window.setInterval(() => {
      this.frameIndex++;

      if (this.frameIndex >= this.frameBuffer.length) {
        // All frames played
        this.stopFramePlayback();
        console.log('[LAM Playback] Frame playback completed');
        return;
      }

      this.applyFrame(this.frameIndex);
    }, frameInterval);
  }

  public stopFramePlayback(): void {
    if (this.framePlaybackTimer) {
      clearInterval(this.framePlaybackTimer);
      this.framePlaybackTimer = null;
    }
    this.isPlayingFrames = false;

    // Reset to idle expression after a short delay
    setTimeout(() => {
      if (!this.isPlayingFrames) {
        this.resetExpression();
        this.setChatState('Idle');
      }
    }, 200);
  }

  private applyFrame(index: number): void {
    if (index >= this.frameBuffer.length) return;

    const frame = this.frameBuffer[index];
    Object.keys(frame).forEach(key => {
      this.expressionData[key] = frame[key];
    });

    // ★ FLAMEモードでもsplatMeshに直接表情を適用
    this.applyExpressionToMesh();

    // Debug log every 10 frames
    if (index % 10 === 0) {
      const jawOpen = frame['jawOpen'] || 0;
      const mouthLD = frame['mouthLowerDownLeft'] || 0;
      console.log(`[LAM Playback] Frame ${index}/${this.frameBuffer.length}: jaw=${jawOpen.toFixed(3)}, mouthLD=${mouthLD.toFixed(3)}`);
    }
  }

  /**
   * Apply expression data directly to splatMesh.bsWeight
   * This is needed because the renderer's setExpression() is not called in FLAME mode
   */
  private applyExpressionToMesh(): void {
    try {
      const renderer = this.renderer as any;
      if (renderer?.viewer?.splatMesh) {
        // Directly set bsWeight on splatMesh (bypasses FLAME animation)
        renderer.viewer.splatMesh.bsWeight = { ...this.expressionData };
      }
    } catch (e) {
      // Silently ignore if renderer structure is different
    }
  }

  private resetExpression(): void {
    // Reset all expression channels to 0
    ARKIT_CHANNEL_NAMES.forEach(name => {
      this.expressionData[name] = 0;
    });
    // Apply reset to mesh
    this.applyExpressionToMesh();
  }

  // Public API for external control

  public getChatState(): ChatState {
    return this.currentState;
  }

  public setChatState(state: ChatState) {
    console.log(`[LAM Avatar] setChatState: ${this.currentState} → ${state}`);
    this.currentState = state;
    // Emit event for other components
    this.container.dispatchEvent(new CustomEvent('lamStateChange', {
      detail: { state }
    }));
  }

  public getExpressionData(): ExpressionData {
    // レンダラーがオブジェクトを変更するため、コピーを返す（値の爆発を防止）
    return { ...this.expressionData };
  }

  public setExpressionData(data: ExpressionData) {
    this.expressionData = data;
  }

  // Update expression from Audio2Expression output (manual mode)
  public updateFromAudio2Expression(frameData: { names: string[], weights: number[] }) {
    const newExpression: ExpressionData = {};
    frameData.names.forEach((name, index) => {
      newExpression[name] = frameData.weights[index];
    });
    this.expressionData = newExpression;
  }

  // Send end speech signal to backend
  public sendEndSpeech(): void {
    this.wsManager?.sendEndSpeech();
  }

  /**
   * Queue expression frames from external source (REST API)
   * Use this when expression data comes from a REST API instead of WebSocket
   * @param frames - Array of expression frames
   * @param frameRate - Frame rate (default 30fps)
   */
  public queueExpressionFrames(frames: ExpressionData[], frameRate: number = 30): void {
    if (!frames || frames.length === 0) {
      console.warn('[LAM Avatar] queueExpressionFrames called with no frames');
      return;
    }

    this.frameQueue.push(frames);
    this.frameRate = frameRate;
    this.waitingForAudio = true;
    console.log(`[LAM Avatar] Queued ${frames.length} expression frames at ${frameRate}fps`);
  }

  // Get WebSocket manager for advanced usage
  public getWebSocketManager(): LAMWebSocketManager | null {
    return this.wsManager;
  }
}

// Initialize when DOM is ready
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('lamAvatarContainer');
  if (container) {
    // Expose controller globally for external access
    (window as any).lamAvatarController = new LAMAvatarController(container);
  }
});

// Export for module usage
export { LAMAvatarController };
</script>
