---
// LAMAvatar.astro - LAM 3D Avatar Component using gaussian-splat-renderer-for-lam
// This component renders a 3D avatar using WebGL Gaussian Splatting
// With OpenAvatarChat WebSocket integration for real-time lip sync

export interface Props {
  avatarPath?: string;  // Path to avatar .zip file
  width?: string;
  height?: string;
  wsUrl?: string;       // WebSocket URL for OpenAvatarChat backend
  autoConnect?: boolean; // Auto-connect to WebSocket on load
}

const {
  avatarPath = '/avatar/concierge.zip',
  width = '100%',
  height = '100%',
  wsUrl = '',
  autoConnect = false
} = Astro.props;
---

<div
  class="lam-avatar-container"
  id="lamAvatarContainer"
  data-avatar-path={avatarPath}
  data-ws-url={wsUrl}
  data-auto-connect={autoConnect.toString()}
  style={`width: ${width}; height: ${height};`}
>
  <div class="lam-avatar-canvas" id="lamAvatarCanvas"></div>
  <div class="lam-avatar-loading" id="lamAvatarLoading">
    <div class="spinner"></div>
    <p>Loading 3D Avatar...</p>
  </div>
  <div class="lam-avatar-fallback" id="lamAvatarFallback">
    <img src="/images/avatar-anime.png" alt="AI Avatar" class="fallback-img" />
  </div>
</div>

<style>
.lam-avatar-container {
  position: relative;
  background: transparent;
  overflow: hidden;
}

.lam-avatar-canvas {
  width: 100%;
  height: 100%;
  display: none;
}

.lam-avatar-canvas.ready {
  display: block;
}

.lam-avatar-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  z-index: 10;
}

.lam-avatar-loading.hidden {
  display: none;
}

.lam-avatar-loading .spinner {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(6, 182, 212, 0.3);
  border-top-color: #06b6d4;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 12px;
}

.lam-avatar-loading p {
  color: #0891b2;
  font-size: 14px;
  font-weight: 500;
}

.lam-avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lam-avatar-fallback.hidden {
  display: none;
}

.fallback-img {
  max-width: 80%;
  max-height: 80%;
  object-fit: contain;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
</style>

<script>
/**
 * LAM Avatar Controller with OpenAvatarChat WebSocket Integration
 *
 * Usage in your local environment:
 * 1. Install NPM package: npm install gaussian-splat-renderer-for-lam
 * 2. Place avatar .zip file in public/avatar/ directory
 * 3. Connect to OpenAvatarChat backend for real-time lip sync
 */

import {
  LAMWebSocketManager,
  type ExpressionData,
  type MotionData
} from '../scripts/lam/lam-websocket-manager';

type ChatState = 'Idle' | 'Listening' | 'Thinking' | 'Responding';

class LAMAvatarController {
  private container: HTMLElement;
  private canvas: HTMLElement;
  private loading: HTMLElement;
  private fallback: HTMLElement;
  private avatarPath: string;
  private wsUrl: string;
  private autoConnect: boolean;
  private renderer: any = null;
  private wsManager: LAMWebSocketManager | null = null;
  private currentState: ChatState = 'Idle';
  private expressionData: ExpressionData = {};
  private isInitialized = false;
  private audioContext: AudioContext | null = null;
  private audioQueue: Int16Array[] = [];
  private isPlayingAudio = false;

  constructor(container: HTMLElement) {
    this.container = container;
    this.canvas = container.querySelector('#lamAvatarCanvas') as HTMLElement;
    this.loading = container.querySelector('#lamAvatarLoading') as HTMLElement;
    this.fallback = container.querySelector('#lamAvatarFallback') as HTMLElement;
    this.avatarPath = container.dataset.avatarPath || '/avatar/concierge.zip';
    this.wsUrl = container.dataset.wsUrl || '';
    this.autoConnect = container.dataset.autoConnect === 'true';

    this.init();
  }

  private async init() {
    try {
      // Try to load the LAM WebGL renderer
      await this.loadRenderer();

      // Auto-connect to WebSocket if configured
      if (this.autoConnect && this.wsUrl) {
        await this.connectWebSocket(this.wsUrl);
      }
    } catch (error) {
      console.warn('LAM WebGL renderer not available, using fallback image:', error);
      this.showFallback();
    }
  }

  private async loadRenderer() {
    // Dynamic import of the gaussian-splat-renderer-for-lam package
    // This will fail gracefully if the package is not installed
    try {
      const GaussianSplats3D = await import('gaussian-splat-renderer-for-lam');

      this.renderer = await GaussianSplats3D.GaussianSplatRenderer.getInstance(
        this.canvas,
        this.avatarPath,
        {
          getChatState: () => this.getChatState(),
          getExpressionData: () => this.getExpressionData(),
          backgroundColor: '0xbae6fd', // Light blue background
          alpha: 0.0 // Transparent background
        }
      );

      this.isInitialized = true;
      this.showCanvas();
      console.log('LAM Avatar initialized successfully');
    } catch (error) {
      throw new Error(`Failed to load LAM renderer: ${error}`);
    }
  }

  private showCanvas() {
    this.loading.classList.add('hidden');
    this.fallback.classList.add('hidden');
    this.canvas.classList.add('ready');
  }

  private showFallback() {
    this.loading.classList.add('hidden');
    this.canvas.classList.remove('ready');
    this.fallback.classList.remove('hidden');
  }

  // WebSocket connection management

  public async connectWebSocket(url: string): Promise<void> {
    if (this.wsManager) {
      this.wsManager.disconnect();
    }

    this.wsManager = new LAMWebSocketManager({
      onExpressionUpdate: (data: ExpressionData) => {
        this.expressionData = data;
      },
      onAudioData: (audio: Int16Array) => {
        this.queueAudio(audio);
      },
      onConnectionChange: (connected: boolean) => {
        this.container.dispatchEvent(new CustomEvent('lamConnectionChange', {
          detail: { connected }
        }));
        if (connected) {
          this.setChatState('Idle');
        }
      }
    });

    await this.wsManager.connect(url);
    console.log('[LAM Avatar] WebSocket connected to:', url);
  }

  public disconnectWebSocket(): void {
    if (this.wsManager) {
      this.wsManager.disconnect();
      this.wsManager = null;
    }
  }

  public isWebSocketConnected(): boolean {
    return this.wsManager?.isConnected() ?? false;
  }

  // Audio playback

  private async initAudioContext(): Promise<void> {
    if (!this.audioContext) {
      this.audioContext = new AudioContext({ sampleRate: 16000 });
    }
    if (this.audioContext.state === 'suspended') {
      await this.audioContext.resume();
    }
  }

  private queueAudio(audio: Int16Array): void {
    this.audioQueue.push(audio);
    if (!this.isPlayingAudio) {
      this.playNextAudio();
    }
  }

  private async playNextAudio(): Promise<void> {
    if (this.audioQueue.length === 0) {
      this.isPlayingAudio = false;
      return;
    }

    this.isPlayingAudio = true;
    await this.initAudioContext();

    const audio = this.audioQueue.shift()!;
    const audioBuffer = this.audioContext!.createBuffer(1, audio.length, 16000);
    const channelData = audioBuffer.getChannelData(0);

    // Convert Int16 to Float32 (-1.0 to 1.0)
    for (let i = 0; i < audio.length; i++) {
      channelData[i] = audio[i] / 32768.0;
    }

    const source = this.audioContext!.createBufferSource();
    source.buffer = audioBuffer;
    source.connect(this.audioContext!.destination);
    source.onended = () => this.playNextAudio();
    source.start();
  }

  public stopAudio(): void {
    this.audioQueue = [];
    this.isPlayingAudio = false;
  }

  // Public API for external control

  public getChatState(): ChatState {
    return this.currentState;
  }

  public setChatState(state: ChatState) {
    this.currentState = state;
    // Emit event for other components
    this.container.dispatchEvent(new CustomEvent('lamStateChange', {
      detail: { state }
    }));
  }

  public getExpressionData(): ExpressionData {
    return this.expressionData;
  }

  public setExpressionData(data: ExpressionData) {
    this.expressionData = data;
  }

  // Update expression from Audio2Expression output (manual mode)
  public updateFromAudio2Expression(frameData: { names: string[], weights: number[] }) {
    const newExpression: ExpressionData = {};
    frameData.names.forEach((name, index) => {
      newExpression[name] = frameData.weights[index];
    });
    this.expressionData = newExpression;
  }

  // Send end speech signal to backend
  public sendEndSpeech(): void {
    this.wsManager?.sendEndSpeech();
  }

  // Get WebSocket manager for advanced usage
  public getWebSocketManager(): LAMWebSocketManager | null {
    return this.wsManager;
  }
}

// Initialize when DOM is ready
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('lamAvatarContainer');
  if (container) {
    // Expose controller globally for external access
    (window as any).lamAvatarController = new LAMAvatarController(container);
  }
});

// Export for module usage
export { LAMAvatarController };
</script>
